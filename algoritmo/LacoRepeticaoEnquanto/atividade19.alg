algoritmo "Nome do Programa"
//
var
valorDigitado : inteiro
soma : real
inicio
soma <-0
escreva("Digite um valor para a soma: ")
leia(valorDigitado)

enquanto (valorDigitado <10) <> 0 faca
soma <- soma + valorDigitado
    escreval ("Total:", soma)

escreva("Digite um valor para a soma: ")
leia(valorDigitado)
fimenquanto

escreva("Resultado: ",soma)

fimalgoritmo