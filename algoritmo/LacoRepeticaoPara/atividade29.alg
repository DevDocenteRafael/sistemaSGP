algoritmo "Nome do Programa"
// Crie um programa usando o "PARA" que calcular a média de 4 números inseridos pelo usuário.
var
contador, numero, soma, media: inteiro

inicio
para contador de 1 ate 4  faca
escreva("Digite o número ",contador,": ")
leia(numero)
    soma <- soma + numero
fimpara
media <- soma/4
escreva("A média foi: ", media)
fimalgoritmo